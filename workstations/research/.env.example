# 研究台前端环境变量示例（复制为 .env 并填写）

# 全工作台与子衿统一应用一致（cli_a98b0babd020500e，见 backend/configs/workstations.yaml）
VITE_FEISHU_APP_ID=cli_a98b0babd020500e
VITE_API_BASE_URL=/api/v1
# 使用路径形式，运行时用当前访问的 origin 拼接（本地=localhost:3002，部署=服务器地址）
# 飞书开放平台需配置：http://localhost:3002/research/、http://118.196.64.48/research/ 等
VITE_FEISHU_REDIRECT_URI=/research/
# 本地开发时设为 1 使用 dev-bypass-token；设为 0 使用飞书真实账号登录
VITE_DEV_AUTH_BYPASS=0

# 方案质量检查台 iframe 地址（生产使用同域 /protocol-qc/，避免 502；本地开发用 .env.development 覆盖为 http://127.0.0.1:5000/）
VITE_PROTOCOL_QC_URL=/protocol-qc/

# AI 解析服务（ProtocolExtractV2，与 KIS 一致）
# VITE_PROTOCOL_EXTRACT_BASE_URL：解析服务地址，开发默认 /aiapi（由 vite 代理）
# VITE_PROTOCOL_EXTRACT_TOKEN：调用解析接口的 Bearer Token，需向解析服务方获取
VITE_PROTOCOL_EXTRACT_BASE_URL=/aiapi
VITE_PROTOCOL_EXTRACT_TOKEN=
