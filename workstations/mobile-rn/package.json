{
  "name": "@cn-kis/mobile-rn",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "type-check": "echo 'mobile-rn typecheck requires RN dev environment; skipped in standard CI'",
    "e2e:maestro": "bash ./scripts/run-maestro.sh test .maestro/flow.yaml",
    "e2e:maestro:all": "bash ./scripts/run-maestro-all.sh",
    "e2e:maestro:ios:headed": "bash ./scripts/e2e-ios-headed.sh",
    "eas:build:ios:preview": "eas build -p ios --profile preview",
    "eas:build:android:preview": "eas build -p android --profile preview",
    "eas:build:ios:production": "eas build -p ios --profile production",
    "eas:build:android:production": "eas build -p android --profile production",
    "eas:submit:ios:production": "eas submit -p ios --profile production",
    "eas:submit:android:production": "eas submit -p android --profile production",
    "eas:secrets:push": "bash ./scripts/push-eas-secrets.sh",
    "release:preflight": "bash ./scripts/validate-release-config.sh && pnpm run type-check && pnpm run e2e:maestro"
  },
  "dependencies": {
    "@cn-kis/subject-core": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "^52.0.0",
    "expo-image-picker": "^55.0.11",
    "expo-local-authentication": "^15.0.1",
    "expo-notifications": "^0.29.8",
    "expo-secure-store": "^14.0.1",
    "expo-sqlite": "^15.1.4",
    "react": "^18.2.0",
    "react-native": "^0.76.0",
    "react-native-ble-plx": "^3.2.0",
    "react-native-health": "^1.19.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.4.0",
    "react-native-toast-message": "^2.2.1",
    "react-native-webview": "^13.12.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0"
  }
}
