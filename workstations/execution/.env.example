# 维周·执行台前端环境变量示例（复制为 .env 后使用）
# 必须与 backend/.env 的 FEISHU_APP_ID 完全一致；与 feishu-sdk 开发回退不一致时会 20024 invalid_grant。
#
# 若登录报 AUTH_OAUTH_FAILED:20002:invalid_client：backend/.env 中 FEISHU_APP_SECRET 须为飞书应用真实密钥（非占位符）。
# 本地暂无密钥时：设 VITE_DEV_AUTH_BYPASS=1，并保证后端 DJANGO_DEBUG=true，可跳过 OAuth 联调界面。
VITE_FEISHU_APP_ID=cli_a98b0babd020500e
VITE_API_BASE_URL=/api/v1
VITE_FEISHU_REDIRECT_BASE=http://localhost:3007
VITE_DEV_AUTH_BYPASS=0
