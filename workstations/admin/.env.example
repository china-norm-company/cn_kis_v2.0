# 鹿鸣·治理台 — 与秘书台共用子衿飞书应用（复制为 .env 后使用）
# 必须与后端 FEISHU_APP_ID / FEISHU_PRIMARY_APP_ID 一致；若此处与其它应用的 App ID 不一致，
# 而授权码实际由该应用签发，后端 force_primary 换凭证换码会失败或行为异常
# 子衿 App ID 见 docs/CONFIG_MANAGEMENT.md，与秘书台 workstations/secretary/.env 一致
VITE_FEISHU_APP_ID=cli_a907f21f0723dbce
VITE_API_BASE_URL=/api/v1
VITE_FEISHU_REDIRECT_BASE=http://localhost:3008
VITE_DEV_AUTH_BYPASS=0
