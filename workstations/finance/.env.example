# 管仲·财务台前端环境变量示例（复制为 .env 后使用）
# 须与 backend/.env 的 FEISHU_APP_ID 完全一致；与 feishu-sdk 开发回退不一致时会 20024 invalid_grant。
# 飞书「重定向 URL」须与 OAuth redirect_uri 一致（本地多为 http://localhost:3004/finance/ 等，见 feishu-sdk 与各台 vite base）。
VITE_FEISHU_APP_ID=cli_a98b0babd020500e
VITE_API_BASE_URL=/api/v1
# 默认已联后端（与 env.ts 默认 real 一致）；纯离线可改为 mock（数据在 localStorage）
# VITE_API_MODE=mock
VITE_API_MODE=real
VITE_FEISHU_REDIRECT_BASE=http://localhost:3004
VITE_DEV_AUTH_BYPASS=0
# 可选：OAuth 走已部署服务器中转时填写部署 API 根，例如：https://your-prod.example.com/api/v1
# VITE_FEISHU_OAUTH_RELAY_API_BASE=
