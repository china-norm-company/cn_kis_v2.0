# 子衿·秘书台前端环境变量示例（复制为 .env 后使用）
# 必须与 backend/.env 的 FEISHU_APP_ID 完全一致；与 feishu-sdk 开发回退不一致时会 20024 invalid_grant。
# 飞书开放平台「安全设置 → 重定向 URL」须包含本地 OAuth 回调（与 redirect_uri 完全一致）：
#   http://localhost:3001/secretary/login
# （开发环境使用 /secretary/login；生产域名多为 https://你的域名/login，见 deploy/nginx.conf）
# 否则授权页报 20029。
VITE_FEISHU_APP_ID=cli_a98b0babd020500e
VITE_API_BASE_URL=/api/v1
VITE_FEISHU_REDIRECT_BASE=http://localhost:3001
VITE_DEV_AUTH_BYPASS=0
