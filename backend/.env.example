# 后端环境变量示例 — CN KIS V2.0
# 复制此文件为 .env，按实际情况填写
# ⚠️ 不要把 .env 提交到版本库

# ============================================================
# Django 基础配置
# ============================================================
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,test-guide.data-infact.com

# ============================================================
# 数据库（默认使用 PostgreSQL；本地开发可用 SQLite）
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/cn_kis_v2
# 本地 SQLite 模式（开发用）
# USE_SQLITE=true

# ============================================================
# Redis（Celery 消息队列）
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 飞书应用配置
# ============================================================
# 主凭证：OAuth 换 token、FEISHU_APP_CREDENTIALS 必须包含此 app_id
# 子衿·秘书台应用示例：cli_a907f21f0723dbce（与前端秘书台 VITE_FEISHU_APP_ID 一致）
FEISHU_APP_ID=cli_a907f21f0723dbce
FEISHU_APP_SECRET=your-feishu-app-secret
# 可选；未设置时回退到 FEISHU_APP_ID，再回退到代码内默认
# FEISHU_PRIMARY_APP_ID=
FEISHU_PRIMARY_AUTH_FORCE=1

# ============================================================
# AI 智能体
# ============================================================
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
KIMI_API_KEY=your-kimi-api-key

# ============================================================
# 向量化与知识库
# ============================================================
JINA_API_KEY=your-jina-api-key
QDRANT_URL=http://localhost:6333
VOLCENGINE_KB_COLLECTION=cn_kis_v2_test

# ============================================================
# 易快报（合思费控）
# ============================================================
EKB_CORP_ID=nYA6xdjChA7c00
EKB_HOST=dd2.hosecloud.com

# ============================================================
# 环境标识
# ============================================================
ENVIRONMENT=test
DB_PREFIX=t

# ============================================================
# 智能运营早晚报 & 用户反馈系统（Issue #4）
# ============================================================
# 飞书开发小组群 chat_id（早晚报推送目标群）
# 获取方式：飞书群设置 → 群机器人 → 复制 chat_id
FEISHU_DEV_GROUP_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 用户反馈群 chat_id（接收用户反馈消息的群）
FEISHU_FEEDBACK_GROUP_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件验证 Token（可选，从飞书开发者后台「事件订阅」页面获取）
FEISHU_VERIFICATION_TOKEN=

# GitHub Personal Access Token（用于创建 Issue 和读取仓库数据）
# 权限：repo（仓库读写）
# 创建：https://github.com/settings/tokens → Generate new token (classic)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub 仓库信息（用于自动创建 Issue）
GITHUB_REPO_OWNER=china-norm-company
GITHUB_REPO_NAME=cn_kis_v2.0

# ============================================================
# ⚠️ 测试环境专属（生产环境删除此块）
# ============================================================
# 禁用生产采集类 Celery Beat 任务（V2 迁移章程红线要求）
CELERY_PRODUCTION_TASKS_DISABLED=true
