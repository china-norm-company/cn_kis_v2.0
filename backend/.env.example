# 后端环境变量示例 — CN KIS V2.0
# 复制此文件为 .env，按实际情况填写
# ⚠️ 不要把 .env 提交到版本库

# ============================================================
# Django 基础配置
# ============================================================
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,test-guide.data-infact.com

# ============================================================
# 数据库（默认使用 PostgreSQL；本地开发可用 SQLite）
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/cn_kis_v2
# true = 使用 SQLite（db.sqlite3）；false = 使用下方 DB_* 连接 PostgreSQL
# USE_SQLITE=true

# ============================================================
# 邮件（SMTP）— 双签核验等；开发可改用 console 后端
# ============================================================
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=libs.smtp_email_backend.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
# 仅开发排查证书问题时使用，生产勿开启
EMAIL_SMTP_INSECURE_SKIP_VERIFY=false

# 执行台公网根 URL（邮件内链接）；知情扫码测试落地（手机可访问的 API 根，无 /api 后缀）
# EXECUTION_PUBLIC_BASE_URL=http://127.0.0.1:3007
# CONSENT_TEST_SCAN_PUBLIC_BASE=http://YOUR_LAN_IP:8001

# 双签邮件人脸联调（跳过火山；本地先展示「人脸核验完成」再进授权/签名）。生产务必 false
# WITNESS_FACE_DEV_BYPASS=false

# ============================================================
# Redis（Celery 消息队列）
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 飞书应用配置
# ============================================================
# 主授权应用（子衿 cli_a98b0babd020500e）— OAuth 统一签发 + 数据采集
# 须与各 workstations/*/.env 的 VITE_FEISHU_APP_ID、packages/feishu-sdk PRIMARY_APP_ID_FALLBACK 一致
# 子衿主授权时：所有工作台 OAuth 可统一使用 FEISHU_APP_ID（子衿），见 config/feishu.yaml
#
# 【本机无 PostgreSQL】开发页面/小程序联调时：设为 USE_SQLITE=true，数据落在 backend/db.sqlite3，
# 避免与本机 5432 或远程库混用导致「数据跳来跳去」。见 docs/BACKEND_LOCAL_SETUP_WINDOWS.md
FEISHU_APP_ID=cli_a98b0babd020500e
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_PRIMARY_AUTH_FORCE=1
# 本地开发执行台时与 VITE_FEISHU_REDIRECT_BASE 对齐，例如 http://localhost:3007（勿与 127.0.0.1 混用）
# FEISHU_REDIRECT_BASE=http://localhost:3007
# 机器人发群通知用的 chat_id（oc_ 开头）。可不手填，用租户 token 拉群列表解析：
#   python manage.py feishu_list_bot_chats --match "群名称子串"
# FEISHU_NOTIFICATION_CHAT_ID=

# ============================================================
# AI 智能体
# ============================================================
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
KIMI_API_KEY=your-kimi-api-key

# ============================================================
# 向量化与知识库
# ============================================================
JINA_API_KEY=your-jina-api-key
QDRANT_URL=http://localhost:6333
VOLCENGINE_KB_COLLECTION=cn_kis_v2_test

# ============================================================
# 易快报（合思费控）
# ============================================================
EKB_CORP_ID=nYA6xdjChA7c00
EKB_HOST=dd2.hosecloud.com

# ============================================================
# 环境标识
# ============================================================
ENVIRONMENT=test
DB_PREFIX=t

# ============================================================
# ⚠️ 测试环境专属（生产环境删除此块）
# ============================================================
# 禁用生产采集类 Celery Beat 任务（V2 迁移章程红线要求）
CELERY_PRODUCTION_TASKS_DISABLED=true
