        {"id": "l_value", "type": "number", "title": "L* 值（明度）", "required": true, "min": 0, "max": 100, "step": 0.01, "repeat": 3, "auto_average": true},
        {"id": "a_value", "type": "number", "title": "a* 值（红绿）", "required": true, "min": -60, "max": 60, "step": 0.01, "repeat": 3, "auto_average": true},
        {"id": "b_value", "type": "number", "title": "b* 值（黄蓝）", "required": true, "min": -60, "max": 60, "step": 0.01, "repeat": 3, "auto_average": true},
        {"id": "notes", "type": "textarea", "title": "备注", "required": false}
      ]
    }
  },
  {
