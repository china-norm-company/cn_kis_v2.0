[
  {
    "name": "皮肤水分测试（Corneometer）",
    "version": "1.0",
    "description": "使用 Corneometer CM 825 测量皮肤角质层水分含量",
    "schema": {
      "title": "皮肤水分测试",
      "description": "Corneometer CM 825 水分含量测试记录",
      "questions": [
        {"id": "test_site", "type": "select", "title": "测试部位", "required": true, "options": [
          {"label": "前额", "value": "forehead"}, {"label": "左脸颊", "value": "left_cheek"},
          {"label": "右脸颊", "value": "right_cheek"}, {"label": "下巴", "value": "chin"},
          {"label": "前臂内侧", "value": "inner_forearm"}, {"label": "手背", "value": "back_of_hand"}
        ]},
        {"id": "moisture_value", "type": "number", "title": "水分值", "required": true, "unit": "AU", "min": 0, "max": 130, "repeat": 3, "auto_average": true},
        {"id": "env_temperature", "type": "number", "title": "环境温度", "required": true, "unit": "°C", "min": 15, "max": 30, "step": 0.1},
        {"id": "env_humidity", "type": "number", "title": "环境湿度", "required": true, "unit": "%RH", "min": 30, "max": 70, "step": 0.1},
        {"id": "acclimation_time", "type": "number", "title": "受试者适应时间", "required": true, "unit": "分钟", "min": 15, "max": 60},
        {"id": "notes", "type": "textarea", "title": "备注", "required": false}
      ]
    }
  },
  {
