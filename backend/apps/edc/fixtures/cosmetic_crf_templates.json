          {"label": "1 - 轻度红斑", "value": "1"}, {"label": "2 - 红斑+水肿", "value": "2"},
          {"label": "3 - 红斑+水肿+丘疹", "value": "3"}, {"label": "4 - 红斑+水肿+水疱", "value": "4"}
        ]},
