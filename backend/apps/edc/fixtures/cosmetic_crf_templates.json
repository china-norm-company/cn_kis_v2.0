          {"label": "前额", "value": "forehead"}, {"label": "眼角", "value": "eye_corner"},
          {"label": "脸颊", "value": "cheek"}, {"label": "前臂内侧", "value": "inner_forearm"}
        ]},
        {"id": "r0", "type": "number", "title": "R0（Uf - 最终变形）", "required": true, "min": 0, "max": 1, "step": 0.001},
        {"id": "r1", "type": "number", "title": "R1（Uf - Ua）", "required": true, "min": 0, "max": 1, "step": 0.001},
        {"id": "r2", "type": "number", "title": "R2（Ua/Uf - 总体弹性）", "required": true, "min": 0, "max": 1, "step": 0.001},
        {"id": "r5", "type": "number", "title": "R5（Ur/Ue - 净弹性）", "required": true, "min": 0, "max": 1, "step": 0.001},
        {"id": "r7", "type": "number", "title": "R7（Ur/Uf - 生物弹性）", "required": true, "min": 0, "max": 1, "step": 0.001},
        {"id": "measurement_count", "type": "number", "title": "测量次数", "required": true, "min": 1, "max": 10},
        {"id": "suction_time", "type": "number", "title": "吸引时间", "required": true, "unit": "秒", "min": 1, "max": 10},
        {"id": "notes", "type": "textarea", "title": "备注", "required": false}
      ]
    }
  },
  {
    "name": "面部图像拍摄（VISIA-CR）",
    "version": "1.0",
    "description": "使用 VISIA-CR 系统进行标准化面部图像拍摄",
    "schema": {
      "title": "VISIA-CR 面部图像记录",
      "description": "标准化面部图像拍摄参数记录",
      "questions": [
        {"id": "capture_angle", "type": "checkbox", "title": "拍摄角度", "required": true, "options": [
          {"label": "正面 (0°)", "value": "front"},
          {"label": "左侧 45°", "value": "left_45"},
          {"label": "右侧 45°", "value": "right_45"},
          {"label": "左侧 90°", "value": "left_90"},
          {"label": "右侧 90°", "value": "right_90"}
        ]},
        {"id": "image_id_front", "type": "text", "title": "正面图片编号", "required": true},
        {"id": "image_id_left", "type": "text", "title": "左45°图片编号", "required": true},
        {"id": "image_id_right", "type": "text", "title": "右45°图片编号", "required": true},
        {"id": "exposure_mode", "type": "select", "title": "曝光模式", "required": true, "options": [
          {"label": "标准光", "value": "standard"}, {"label": "交叉偏振光", "value": "cross_polarized"},
          {"label": "平行偏振光", "value": "parallel_polarized"}, {"label": "UV 光", "value": "uv"}
        ]},
        {"id": "analysis_modules", "type": "checkbox", "title": "分析模块", "required": false, "options": [
          {"label": "斑点", "value": "spots"}, {"label": "皱纹", "value": "wrinkles"},
          {"label": "纹理", "value": "texture"}, {"label": "毛孔", "value": "pores"},
          {"label": "UV 斑", "value": "uv_spots"}, {"label": "棕色斑", "value": "brown_spots"},
          {"label": "红色区域", "value": "red_areas"}, {"label": "紫质", "value": "porphyrins"}
        ]},
        {"id": "notes", "type": "textarea", "title": "备注", "required": false}
      ]
    }
  },
  {
    "name": "皮肤色度测试（色差仪）",
    "version": "1.0",
    "description": "使用色差仪（CM-700d/CR-400）测量皮肤色度 L*a*b* 值",
    "schema": {
      "title": "皮肤色度测试",
      "description": "L*a*b* 色度值记录",
      "questions": [
        {"id": "test_site", "type": "select", "title": "测试部位", "required": true, "options": [
          {"label": "前额", "value": "forehead"}, {"label": "脸颊", "value": "cheek"},
          {"label": "前臂内侧", "value": "inner_forearm"}, {"label": "手背", "value": "back_of_hand"}
        ]},
        {"id": "light_source", "type": "select", "title": "标准光源", "required": true, "options": [
          {"label": "D65", "value": "D65"}, {"label": "A", "value": "A"}, {"label": "C", "value": "C"}
