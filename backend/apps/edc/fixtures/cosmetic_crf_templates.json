  {
    "name": "主观评估问卷（专家评分）",
    "version": "1.0",
    "description": "皮肤科专家主观评估问卷",
    "schema": {
      "title": "专家主观评估",
      "description": "皮肤科专家视觉评估记录",
      "questions": [
        {"id": "skin_hydration", "type": "scale", "title": "皮肤水润度", "required": true, "min": 0, "max": 10, "step": 1},
        {"id": "skin_smoothness", "type": "scale", "title": "皮肤光滑度", "required": true, "min": 0, "max": 10, "step": 1},
        {"id": "skin_brightness", "type": "scale", "title": "皮肤亮泽度", "required": true, "min": 0, "max": 10, "step": 1},
        {"id": "wrinkle_severity", "type": "scale", "title": "皱纹严重度", "required": true, "min": 0, "max": 10, "step": 1},
        {"id": "pore_visibility", "type": "scale", "title": "毛孔可见度", "required": true, "min": 0, "max": 10, "step": 1},
