# ============================================================
# CN KIS V2.0 — 生产环境变量模板（火山云 ECS 118.196.64.48）
# ============================================================
# 使用说明：
#   1. 复制此文件为 backend/.env（不要提交到 git）
#   2. 填写所有 your-xxx 占位符
#   3. 与测试环境 .env.test.example 的关键差异见底部差异表
#
# ⚠️ 与测试环境的关键差异（切换时必须核对）：
#
#   变量                              测试值                  生产值
#   ─────────────────────────────────────────────────────────
#   ENVIRONMENT                       test                    production
#   CELERY_PRODUCTION_TASKS_DISABLED  true                    （不设置 / false）
#   REDIS_URL                         redis://...:/1          redis://localhost:6379/0
#   VOLCENGINE_KB_COLLECTION          cn_kis_v2_test          cn_kis_v2
#   KNOWLEDGE_WRITE_ENABLED           false                   false（Wave 3 后改 true）
#   DEBUG                             false                   false
#   DJANGO_SECURE_SSL_REDIRECT        false                   true（已配 SSL 后启用）

# ============================================================
# Django 基础配置
# ============================================================
SECRET_KEY=your-production-secret-key-min-50-chars-random
DEBUG=False
DJANGO_ALLOWED_HOSTS=118.196.64.48,china-norm.com,www.china-norm.com,localhost,127.0.0.1
SITE_URL=https://china-norm.com

# ============================================================
# 环境标识（生产环境不得设为 test）
# ============================================================
ENVIRONMENT=production
DB_PREFIX=t

# ============================================================
# 数据库（火山云 PostgreSQL，本机 localhost，V2 独立库）
# ============================================================
DB_NAME=cn_kis_v2
DB_USER=cn_kis
DB_PASSWORD=your-cn-kis-db-password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# Redis（生产使用 DB 0，与测试 DB 1 隔离）
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 飞书配置
# ============================================================
# 主授权应用（子衿）
FEISHU_APP_ID=cli_a98b0babd020500e
FEISHU_APP_SECRET=your-zijin-app-secret
FEISHU_PRIMARY_APP_ID=cli_a98b0babd020500e
FEISHU_PRIMARY_AUTH_FORCE=1

# 鹿鸣·治理台（独立应用）
FEISHU_APP_ID_GOVERNANCE=cli_a937515668b99cc9
FEISHU_APP_SECRET_GOVERNANCE=your-governance-app-secret

# 洞明·数据台（独立应用）
FEISHU_APP_ID_DATA_PLATFORM=cli_a93753da2c381cef
FEISHU_APP_SECRET_DATA_PLATFORM=your-data-platform-app-secret

# OAuth 回调域名（必须与飞书开放平台配置完全一致，含尾部斜杠差异）
FEISHU_REDIRECT_BASE=https://china-norm.com

# 飞书协作群 / 管理员
FEISHU_DEV_GROUP_CHAT_ID=your-dev-group-chat-id
FEISHU_ADMIN_OPEN_ID=your-admin-open-id
FEISHU_WIKI_SPACE_ID=your-wiki-space-id
FEISHU_WIKI_URL=https://your-tenant.feishu.cn/wiki/...
GITHUB_REPO_URL=https://github.com/china-norm-company/cn_kis_v2.0

# ============================================================
# JWT（生产密钥必须与 V1 不同，且不少于 32 位随机字符）
# ============================================================
JWT_SECRET=your-production-jwt-secret-min-32-chars-different-from-v1

# ============================================================
# AI 配置
# ============================================================
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
KIMI_API_KEY=your-kimi-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================================
# 向量化（内网 Qwen3-embedding，唯一授权通道）
# ============================================================
QWEN3_EMBEDDING_URL=http://11nzxz3591157.vicp.fun:49846/Embedding/v1/embeddings
QWEN3_EMBEDDING_KEY=your-qwen3-embedding-key
QDRANT_URL=http://localhost:6333
# 生产集合名（区别于测试的 cn_kis_v2_test）
VOLCENGINE_KB_COLLECTION=cn_kis_v2

# ============================================================
# 易快报（合思费控）
# ============================================================
EKB_CORP_ID=nYA6xdjChA7c00
EKB_HOST=dd2.hosecloud.com

# ============================================================
# 微信小程序（受试者端）
# ============================================================
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# ============================================================
# 火山引擎实名核验
# ============================================================
VOLC_ACCESSKEY=your-volc-accesskey
VOLC_SECRETKEY=your-volc-secretkey
VOLC_ACCOUNT_ID=your-volc-account-id

# ============================================================
# 知识库写保护（Wave 3 完成前保持 false）
# ============================================================
KNOWLEDGE_WRITE_ENABLED=false

# ============================================================
# ✅ 生产环境：以下变量必须【不存在】或设为 false
# ============================================================
# CELERY_PRODUCTION_TASKS_DISABLED=false
# （注释掉或删除此行，生产环境不得设为 true）
#
# 检查命令：
#   grep "CELERY_PRODUCTION_TASKS_DISABLED" /opt/cn-kis-v2/backend/.env
#   # 应输出空（不存在）或 =false
