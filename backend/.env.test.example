# ===========================================================================
# CN KIS V2.0 后端测试环境配置
# 用途：阿里云测试服务器 (test-guide.data-infact.com) 专用
#
# 使用方法：
#   1. 复制本文件为 backend/.env（或直接粘贴到 GitHub Secret BACKEND_DOT_ENV）
#   2. 将 <从V1复制> 标记的变量值从 V1 生产环境获取（飞书App凭证、AI Key 等）
#   3. 保留所有 CELERY_PRODUCTION_TASKS_DISABLED=true 等安全开关（不得删除）
#
# ⚠️  迁移章程红线要求：
#   - CELERY_PRODUCTION_TASKS_DISABLED=true  → 禁止生产采集任务污染测试环境
#   - KNOWLEDGE_WRITE_ENABLED=false          → V2 知识资产初期只读
#   - DB_NAME 使用独立测试库（cn_kis_v2）    → 不共用生产数据库
# ===========================================================================

# ---------------------------------------------------------------------------
# Django 基础配置
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=cn-kis-v2-test-secret-key-please-change-before-launch
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*

# ---------------------------------------------------------------------------
# 数据库（阿里云测试服务器本地 PostgreSQL）
# 使用独立 V2 测试库，不共用 V1 的 cn_kis 库
# ---------------------------------------------------------------------------
DB_NAME=cn_kis_v2
DB_USER=cn_kis
DB_PASSWORD=cn_kis_2026
DB_HOST=host.docker.internal
DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis（阿里云本地 Redis）
# ---------------------------------------------------------------------------
REDIS_URL=redis://host.docker.internal:6379/0

# ---------------------------------------------------------------------------
# 飞书配置（主授权：子衿 cli_a98b0babd020500e）
# ⚠️  从 V1 production 的 deploy/.env.volcengine.plan-a 复制以下值
# ---------------------------------------------------------------------------
FEISHU_APP_ID=<从V1复制: FEISHU_APP_ID>
FEISHU_APP_SECRET=<从V1复制: FEISHU_APP_SECRET>

# 主授权配置（V2 统一授权架构）
FEISHU_PRIMARY_APP_ID=cli_a98b0babd020500e
FEISHU_PRIMARY_AUTH_FORCE=1
FEISHU_PREFLIGHT_BLOCK_SCAN=1

# 测试环境重定向 URI（指向阿里云测试域名）
FEISHU_REDIRECT_URI=http://test-guide.data-infact.com:9001/api/v1/auth/feishu-callback

# 子衿开发助手（用于知识采集 OAuth）
FEISHU_APP_ID_DEV_ASSISTANT=<从V1复制: FEISHU_APP_ID_DEV_ASSISTANT>
FEISHU_APP_SECRET_DEV_ASSISTANT=<从V1复制: FEISHU_APP_SECRET_DEV_ASSISTANT>

# 各工作台独立飞书 App（可选，测试时均可使用子衿主应用）
FEISHU_APP_ID_FINANCE=<从V1复制: FEISHU_APP_ID_FINANCE>
FEISHU_APP_SECRET_FINANCE=<从V1复制: FEISHU_APP_SECRET_FINANCE>
FEISHU_APP_ID_RESEARCH=<从V1复制: FEISHU_APP_ID_RESEARCH>
FEISHU_APP_SECRET_RESEARCH=<从V1复制: FEISHU_APP_SECRET_RESEARCH>
FEISHU_APP_ID_EXECUTION=<从V1复制: FEISHU_APP_ID_EXECUTION>
FEISHU_APP_SECRET_EXECUTION=<从V1复制: FEISHU_APP_SECRET_EXECUTION>
FEISHU_APP_ID_QUALITY=<从V1复制: FEISHU_APP_ID_QUALITY>
FEISHU_APP_SECRET_QUALITY=<从V1复制: FEISHU_APP_SECRET_QUALITY>
FEISHU_APP_ID_HR=<从V1复制: FEISHU_APP_ID_HR>
FEISHU_APP_SECRET_HR=<从V1复制: FEISHU_APP_SECRET_HR>
FEISHU_APP_ID_CRM=<从V1复制: FEISHU_APP_ID_CRM>
FEISHU_APP_SECRET_CRM=<从V1复制: FEISHU_APP_SECRET_CRM>
FEISHU_APP_ID_RECRUITMENT=<从V1复制: FEISHU_APP_ID_RECRUITMENT>
FEISHU_APP_SECRET_RECRUITMENT=<从V1复制: FEISHU_APP_SECRET_RECRUITMENT>
FEISHU_APP_ID_EQUIPMENT=<从V1复制: FEISHU_APP_ID_EQUIPMENT>
FEISHU_APP_SECRET_EQUIPMENT=<从V1复制: FEISHU_APP_SECRET_EQUIPMENT>
FEISHU_APP_ID_MATERIAL=<从V1复制: FEISHU_APP_ID_MATERIAL>
FEISHU_APP_SECRET_MATERIAL=<从V1复制: FEISHU_APP_SECRET_MATERIAL>
FEISHU_APP_ID_FACILITY=<从V1复制: FEISHU_APP_ID_FACILITY>
FEISHU_APP_SECRET_FACILITY=<从V1复制: FEISHU_APP_SECRET_FACILITY>
FEISHU_APP_ID_EVALUATOR=<从V1复制: FEISHU_APP_ID_EVALUATOR>
FEISHU_APP_SECRET_EVALUATOR=<从V1复制: FEISHU_APP_SECRET_EVALUATOR>
FEISHU_APP_ID_LAB_PERSONNEL=<从V1复制: FEISHU_APP_ID_LAB_PERSONNEL>
FEISHU_APP_SECRET_LAB_PERSONNEL=<从V1复制: FEISHU_APP_SECRET_LAB_PERSONNEL>
FEISHU_APP_ID_ETHICS=<从V1复制: FEISHU_APP_ID_ETHICS>
FEISHU_APP_SECRET_ETHICS=<从V1复制: FEISHU_APP_SECRET_ETHICS>
FEISHU_APP_ID_RECEPTION=<从V1复制: FEISHU_APP_ID_RECEPTION>
FEISHU_APP_SECRET_RECEPTION=<从V1复制: FEISHU_APP_SECRET_RECEPTION>
FEISHU_APP_ID_CONTROL_PLANE=<从V1复制: FEISHU_APP_ID_CONTROL_PLANE>
FEISHU_APP_SECRET_CONTROL_PLANE=<从V1复制: FEISHU_APP_SECRET_CONTROL_PLANE>

# ---------------------------------------------------------------------------
# AI 配置（从 V1 复制）
# ---------------------------------------------------------------------------
ARK_API_KEY=<从V1复制: ARK_API_KEY>
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_DEFAULT_MODEL=<从V1复制: ARK_DEFAULT_MODEL>
ARK_EMBEDDING_ENDPOINT=<从V1复制: ARK_EMBEDDING_ENDPOINT>

KIMI_API_KEY=<从V1复制: KIMI_API_KEY>
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-32k

DEEPSEEK_API_KEY=<从V1复制: DEEPSEEK_API_KEY>
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Embedding / 向量化（测试环境可使用 Jina API，不启用本地 GPU）
# ---------------------------------------------------------------------------
JINA_API_KEY=<从V1复制: JINA_API_KEY>
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_EMBEDDING_DIM=1024
KNOWLEDGE_EMBEDDING_STRATEGY=jina

QWEN3_EMBEDDING_URL=<从V1复制: QWEN3_EMBEDDING_URL>
QWEN3_EMBEDDING_KEY=<从V1复制: QWEN3_EMBEDDING_KEY>

# ---------------------------------------------------------------------------
# 协议解析 AI 服务
# ---------------------------------------------------------------------------
PROTOCOL_EXTRACT_V2_BASE_URL=<从V1复制: PROTOCOL_EXTRACT_V2_BASE_URL>
PROTOCOL_EXTRACT_V2_TOKEN=<从V1复制: PROTOCOL_EXTRACT_V2_TOKEN>

# ---------------------------------------------------------------------------
# 微信小程序（测试环境可选，不需要时留空）
# ---------------------------------------------------------------------------
WECHAT_APPID=<从V1复制: WECHAT_APPID>
WECHAT_SECRET=<从V1复制: WECHAT_SECRET>

# ---------------------------------------------------------------------------
# 火山引擎（实名核验，测试环境可不配）
# ---------------------------------------------------------------------------
VOLC_ACCESSKEY=<从V1复制: VOLC_ACCESSKEY>
VOLC_SECRETKEY=<从V1复制: VOLC_SECRETKEY>
VOLC_ACCOUNT_ID=<从V1复制: VOLC_ACCOUNT_ID>

# ---------------------------------------------------------------------------
# 知识库外部服务（测试环境用）
# ---------------------------------------------------------------------------
TAVILY_API_KEY=<从V1复制: TAVILY_API_KEY>
QDRANT_URL=http://host.docker.internal:6333

# ---------------------------------------------------------------------------
# ⚠️  V2 迁移章程安全开关（必须保留，不得修改）
# ---------------------------------------------------------------------------
# 红线 4：测试环境禁止生产采集类 Celery 任务
CELERY_PRODUCTION_TASKS_DISABLED=true

# 红线 3：V2 初期知识资产只读（Wave 3 完成后显式解锁）
KNOWLEDGE_WRITE_ENABLED=false

# ---------------------------------------------------------------------------
# 存储路径（Docker 容器内）
# ---------------------------------------------------------------------------
STORAGE_ROOT=/app/storage
MEDIA_ROOT=/app/media
LOG_DIR=/app/logs

# ---------------------------------------------------------------------------
# 杂项
# ---------------------------------------------------------------------------
USE_SQLITE=false
USE_LOCAL_CACHE=false
DJANGO_SECURE_SSL_REDIRECT=false
CSRF_COOKIE_SECURE=false
