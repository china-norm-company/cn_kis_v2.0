  "description": "CN KIS V2.0 - 基于飞书的多工作台临床研究知识信息系统（重构版）",
  "packageManager": "pnpm@10.28.2",
  "//": "工作台目录已从 apps/ 重命名为 workstations/（V2 架构调整）",
  "scripts": {
    "dev:secretary": "pnpm --filter @cn-kis/secretary dev",
    "dev:research": "pnpm --filter @cn-kis/research dev",
    "dev:quality": "pnpm --filter @cn-kis/quality dev",
    "dev:finance": "pnpm --filter @cn-kis/finance dev",
    "dev:hr": "pnpm --filter @cn-kis/hr dev",
    "dev:crm": "pnpm --filter @cn-kis/crm dev",
    "dev:admin": "pnpm --filter @cn-kis/admin dev",
    "dev:control-plane": "pnpm --filter @cn-kis/control-plane dev",
    "dev:digital-workforce": "pnpm --filter @cn-kis/digital-workforce dev",
    "dev:recruitment": "pnpm --filter @cn-kis/recruitment dev",
    "dev:equipment": "pnpm --filter @cn-kis/equipment dev",
    "dev:material": "pnpm --filter @cn-kis/material dev",
    "dev:facility": "pnpm --filter @cn-kis/facility dev",
    "dev:execution": "pnpm --filter @cn-kis/execution dev",
    "dev:evaluator": "pnpm --filter @cn-kis/evaluator dev",
