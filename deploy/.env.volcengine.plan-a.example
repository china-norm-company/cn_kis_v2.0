# ============================================================
# 火山云方案 A - 环境变量模板
# ============================================================
# 复制为 deploy/.env.volcengine.plan-a 并填入实际值
# 部署时该文件会被复制到 backend/.env
# 参考: docs/VOLCENGINE_INTEGRATION.md、docs/FEISHU_INTEGRATION.md

# ============================================================
# 飞书集成（网页应用 + 机器人 + 飞书开放平台）
# ============================================================
# 飞书开放平台: https://open.feishu.cn/app
# 秘书应用：OAuth 登录、feishu-connector 摸底、日历/审批/邮件等
# ----------------------------------------
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 重定向 URI：与飞书平台「安全设置→重定向 URL」完全一致（无尾部斜杠）
FEISHU_REDIRECT_URI=http://YOUR_SERVER_IP/login

# 各工作台独立飞书应用（每个工作台需在飞书开放平台创建独立网页应用）
# ----------------------------------------
FEISHU_APP_ID_FINANCE=cli_xxx
FEISHU_APP_SECRET_FINANCE=xxx
FEISHU_REDIRECT_URI_FINANCE=http://YOUR_SERVER_IP/finance/login

# 统一平台独立应用（枢）
# ----------------------------------------
FEISHU_APP_ID_CONTROL_PLANE=cli_xxx
FEISHU_APP_SECRET_CONTROL_PLANE=xxx
FEISHU_REDIRECT_URI_CONTROL_PLANE=http://YOUR_SERVER_IP/control-plane/

FEISHU_APP_ID_RESEARCH=cli_xxx
FEISHU_APP_SECRET_RESEARCH=xxx

FEISHU_APP_ID_EXECUTION=cli_xxx
FEISHU_APP_SECRET_EXECUTION=xxx

FEISHU_APP_ID_QUALITY=cli_xxx
FEISHU_APP_SECRET_QUALITY=xxx

FEISHU_APP_ID_HR=cli_xxx
FEISHU_APP_SECRET_HR=xxx

FEISHU_APP_ID_CRM=cli_xxx
FEISHU_APP_SECRET_CRM=xxx

FEISHU_APP_ID_RECRUITMENT=cli_xxx
FEISHU_APP_SECRET_RECRUITMENT=xxx

FEISHU_APP_ID_EQUIPMENT=cli_xxx
FEISHU_APP_SECRET_EQUIPMENT=xxx

FEISHU_APP_ID_MATERIAL=cli_xxx
FEISHU_APP_SECRET_MATERIAL=xxx

FEISHU_APP_ID_FACILITY=cli_xxx
FEISHU_APP_SECRET_FACILITY=xxx

FEISHU_APP_ID_EVALUATOR=cli_xxx
FEISHU_APP_SECRET_EVALUATOR=xxx

FEISHU_APP_ID_LAB_PERSONNEL=cli_xxx
FEISHU_APP_SECRET_LAB_PERSONNEL=xxx

FEISHU_APP_ID_ETHICS=cli_xxx
FEISHU_APP_SECRET_ETHICS=xxx

FEISHU_APP_ID_RECEPTION=cli_xxx
FEISHU_APP_SECRET_RECEPTION=xxx

FEISHU_APP_ID_DIGITAL_WORKFORCE=cli_xxx
FEISHU_APP_SECRET_DIGITAL_WORKFORCE=xxx

FEISHU_APP_ID_DATA_PLATFORM=cli_xxx
FEISHU_APP_SECRET_DATA_PLATFORM=xxx

# 飞书机器人 / 事件订阅（可选）
# ----------------------------------------
# FEISHU_WEBHOOK_TOKEN=xxx
# FEISHU_ENCRYPT_KEY=xxx
# FEISHU_DEFAULT_ROLE=research_manager

# 飞书多维表格（可选）
# ----------------------------------------
# FEISHU_BITABLE_TOKEN=xxx
# FEISHU_BITABLE_TABLE_COLLECTION_RESULTS=tbl_xxx
# FEISHU_BITABLE_TABLE_COOKIE_STORE=tbl_xxx

# 飞书定时同步（秘书工作台，8:30-23:00 每 10 分钟）
# ----------------------------------------
FEISHU_SCHEDULED_SYNC_ENABLED=true

# ── 子衿主授权配置（必须，否则飞书数据采集无权限） ──
# ----------------------------------------
# 背景：子衿是全部18工作台的 OAuth 主签发应用。
#   路径A（生产）：所有工作台 OAuth → 子衿签发 → user_access_token 含全部 scope
#   路径B（旧/回退）：各工作台独立 OAuth → 各自 App ID → 只有基础 scope
# 如果这里不配，settings.py 中 FEISHU_PRIMARY_APP_ID 为空，主授权不生效，
# 所有采集 API 都会报 99991672 权限拒绝。
FEISHU_PRIMARY_APP_ID=cli_xxx
# 强制所有工作台走主授权（=1 启用，=0 回滚到各工作台独立 OAuth）
FEISHU_PRIMARY_AUTH_FORCE=1
# preflight 权限预检拦截开关
FEISHU_PREFLIGHT_BLOCK_SCAN=1

# 飞书 Aily AI 对话（子衿网页应用，AI 走火山引擎 ARK / Kimi）
# ----------------------------------------
# 凭证：智能开发助手（在 open.feishu.cn 创建，Aily 应用发布到此机器人）
FEISHU_APP_ID_DEV_ASSISTANT=cli_a98b0babd020500e
FEISHU_APP_SECRET_DEV_ASSISTANT=CzpFS3DBtRLbx2gxcdXubgSaXNfsoUKZ
# 技能 API 可选：Aily 应用 ID（浏览器地址 spring_xxx__c）、技能 ID（skill_xxx）
# FEISHU_AILY_APP_ID=spring_xxx__c
# FEISHU_AILY_SKILL_ID=skill_xxx
# Agent 推荐：自定义触发器（Webhook）调用，不依赖飞书机器人渠道发布
# FEISHU_AILY_WEBHOOK_URL=https://aily.feishu.cn/...
# FEISHU_AILY_WEBHOOK_BEARER_TOKEN=xxx

# ----------------------------------------
# 微信小程序（受试者端）
# ----------------------------------------
# 微信小程序 AppID
WECHAT_APPID=wx_xxx
# 微信小程序 AppSecret（登录 code2Session 必填）
WECHAT_SECRET=xxx
# 微信支付 APIv3 对称密钥（可选）
# WECHAT_API_SYMMETRIC_KEY=xxx
# 微信支付平台证书公钥（可选，建议使用 \n 转义换行）
# WECHAT_API_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ----------------------------------------
# 数据库（按实际部署填写）
# ----------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/cn_kis

# ----------------------------------------
# Redis（OAuth 防重放、缓存；部署脚本默认写 redis://127.0.0.1:6379/0，可在此覆盖）
# ----------------------------------------
# REDIS_URL=redis://127.0.0.1:6379/0

# ----------------------------------------
# 火山方舟 ARK（复杂任务：协议解析、方案设计、数据分析）
# ----------------------------------------
ARK_API_KEY=xxx
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_DEFAULT_MODEL=ep-xxx
VOLCENGINE_SMART_ROUTER_ENDPOINT=ep-xxx

# ----------------------------------------
# Kimi / Moonshot AI（轻量任务：知识检索、报告生成、通用对话）
# ----------------------------------------
KIMI_API_KEY=sk-xxx
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-32k
# 前端可选模型白名单（逗号分隔）
KIMI_ALLOWED_MODELS=moonshot-v1-8k,moonshot-v1-32k,moonshot-v1-128k
# 通道自动回退（主通道失败后切换备用通道）
AGENT_CHAT_FALLBACK_ENABLED=true

# ----------------------------------------
# Kimi Claw 执行器（托管模式，可选）
# ----------------------------------------
# Kimi Claw 走 Moonshot 标准 baseUrl，不需要独立 KIMI_CLAW_API_BASE
# 若需显式指定，可设置 KIMI_API_BASE 或 MOONSHOT_API_BASE
# MOONSHOT_API_BASE=https://api.moonshot.cn/v1
# 插件执行密钥（可与 KIMI_API_KEY 相同）
# KIMI_PLUGIN_API_KEY=sk-xxx
# 默认任务模板ID（未配置时使用用户约定默认值）
# KIMI_CLAW_TASK_TEMPLATE_ID=19c8d565-df92-8fdc-8000-0000c6875563
# 可选：项目/组织维度上下文（用于平台侧路由与审计）
# KIMI_CLAW_PROJECT_ID=proj-xxx
# KIMI_CLAW_ORG_ID=org-xxx

# ----------------------------------------
# 向量与 Embedding
# ----------------------------------------
EMBEDDING_MODEL=volcengine
VECTOR_STORE=pgvector

# ----------------------------------------
# 火山知识库（可选）
# ----------------------------------------
# VOLCENGINE_KB_PROJECT_DOCS_ID=xxx
# VOLCENGINE_KB_INDUSTRY_ID=xxx
# VOLC_ACCESSKEY=xxx
# VOLC_SECRETKEY=xxx
# VOLCENGINE_KB_ACCOUNT_ID=xxx

# ----------------------------------------
# 火山云身份认证（实名核验，P0 生产必填）
# ----------------------------------------
VOLC_SUB_ACCESSKEY=xxx
VOLC_SUB_SECRETKEY=xxx
VOLC_CERT_ROLE_TRN=trn:iam::xxx:role/IdentityVerifyRole
IDENTITY_VERIFY_H5_CONFIG_ID=xxx

# ----------------------------------------
# 短信服务（P0 生产必填）
# ----------------------------------------
SMS_PROVIDER=volcengine
# 火山云短信凭据
VOLC_SMS_ACCESS_KEY=xxx
VOLC_SMS_SECRET_KEY=xxx
VOLC_SMS_SIGN_NAME=复硕正态
VOLC_SMS_TEMPLATE_CODE=SMS_xxx
VOLC_SMS_ACCOUNT=xxx

# ----------------------------------------
# Redis（Celery + 缓存）
# ----------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# ----------------------------------------
# 通知群聊（按需配置）
# ----------------------------------------
# NOTIFICATION_CHAT_ID=oc_xxx
# RECRUITMENT_NOTIFICATION_CHAT_ID=oc_xxx

# ----------------------------------------
# Django
# ----------------------------------------
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
