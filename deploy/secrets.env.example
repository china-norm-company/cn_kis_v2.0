# ============================================================
# 部署凭据（通讯云优先）
# ============================================================
# 复制为 deploy/secrets.env 并填入实际值
# 部署脚本会自动加载此文件
# 注意：含敏感信息，勿提交到 git

# ========== 通讯云（本次微信小程序部署推荐） ==========
TENCENT_SSH_USER=root
TENCENT_SSH_HOST=118.196.64.48
# TENCENT_SSH_KEY=/path/to/your.pem
# TENCENT_SSH_PASS=请填入服务器root密码

# ========== 火山云控制台（历史兼容，不用于本次小程序部署） ==========
# 用途：登录 https://console.volcengine.com 管理 ECS、创建 ARK API Key、查看账单
VOLCENGINE_CONSOLE_ACCOUNT=请填入手机号或邮箱
VOLCENGINE_CONSOLE_PASS=请填入密码

# ========== 火山云 ECS 服务器 SSH（历史兼容） ==========
# 服务器：从 E2E 继承，火山云 ECS 公网 IP
VOLCENGINE_SSH_USER=root
VOLCENGINE_SSH_HOST=118.196.64.48
# 从 E2E 项目 deploy/secrets.env 复制，或填入实际密码
VOLCENGINE_SSH_PASS=请填入服务器root密码

# ========== SSH 密钥（二选一，优先于密码） ==========
# 若使用密钥认证，配置密钥路径
# VOLCENGINE_SSH_KEY=/path/to/your.pem

# ========== 微信云托管 CLI 部署（腾讯云托管） ==========
# 用于 pnpm run cloudrun:deploy，与小程序 App Secret 不同，需在云托管控制台生成
# 环境：prod，环境 ID：prod-5gedwgmb04c799d6；服务名：django-l3sv
# CLOUDRUN_APP_ID=wx2019d5560fe47b1d
# CLOUDRUN_PRIVATE_KEY=请从微信云托管控制台生成并粘贴
# CLOUDRUN_ENV_ID=prod-5gedwgmb04c799d6
# CLOUDRUN_SERVICE=django-l3sv
